DATABASE_URL="postgresql://postgres:postgres@localhost:5434/asset_management"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
NODE_ENV="development"

# ── Storage driver ─────────────────────────────────────────────────────────────
# "local"  → save files to ./uploads/  (default for local dev)
# "gcs"    → upload to Google Cloud Storage
STORAGE_DRIVER="local"

# Local storage: public URL prefix used to build file URLs (no trailing slash)
BASE_URL="http://localhost:3000"

# GCS storage (only required when STORAGE_DRIVER=gcs)
# GCS_BUCKET_NAME="your-bucket-name"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"
# (On Cloud Run, leave GOOGLE_APPLICATION_CREDENTIALS unset — uses attached SA automatically)
