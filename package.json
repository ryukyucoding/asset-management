{
  "name": "asset-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter ./backend dev\" \"pnpm --filter ./frontend dev\"",
    "dev:backend": "pnpm --filter ./backend dev",
    "dev:frontend": "pnpm --filter ./frontend dev",
    "build": "pnpm --filter ./backend build && pnpm --filter ./frontend build",
    "test": "pnpm --filter ./backend test && pnpm --filter ./frontend test:unit",
    "test:coverage": "pnpm --filter ./backend test:coverage",
    "test:integration": "pnpm --filter ./backend test:integration",
    "test:e2e": "pnpm --filter ./frontend test:e2e",
    "test:load": "k6 run load-tests/smoke.js",
    "test:load:read": "k6 run load-tests/read-heavy.js",
    "test:load:admin": "k6 run load-tests/admin-read.js",
    "test:load:stress": "k6 run load-tests/stress.js",
    "test:load:spike": "k6 run load-tests/spike.js",
    "test:load:soak": "k6 run load-tests/soak.js",
    "test:load:all": "bash load-tests/run-all.sh",
    "test:load:production": "bash load-tests/run-production.sh",
    "test:load:production:heavy": "bash load-tests/run-production-heavy.sh",
    "db:migrate": "pnpm --filter ./backend db:migrate",
    "db:seed": "pnpm --filter ./backend db:seed",
    "db:seed:bulk": "pnpm --filter ./backend db:seed:bulk"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "msgpackr-extract", "prisma"]
  }
}
